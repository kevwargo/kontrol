pkgname=${PKG_NAME}
pkgver=${PKG_VERSION}
pkgrel=1
pkgdesc="${PKG_DESCRIPTION}"
arch=(any)
license=(MIT)

depends=(python python-dbus-next python-yaml python-pyqt6 python-qasync)
makedepends=(python-build python-hatchling python-installer)

source=(${PKG_SOURCE_DIST})
sha256sums=(SKIP)

build() {
    cd ${pkgname}-${pkgver}
    python -m build --wheel --no-isolation
}

package() {
    cd ${pkgname}-${pkgver}

    python -m installer --destdir=${pkgdir} dist/${PKG_NAME}-${PKG_VERSION}*.whl

    install -Dm644 systemd/kwinctl.service ${pkgdir}/usr/lib/systemd/user/kwinctl.service

    for f in kwinctl.js rules.yaml commands.yaml overrides.yaml; do
        install -Dm644 src/kontrol/cli/kwinctl/$f ${pkgdir}/usr/share/kwinctl/$f
    done
}
