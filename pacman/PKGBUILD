pkgname=${PKG_NAME}
pkgver=${PKG_VERSION}
pkgrel=1
pkgdesc="${PKG_DESCRIPTION}"
arch=(any)
license=(MIT)

depends=(python python-dbus-next python-yaml python-pyqt6 python-qasync)
makedepends=(python-build python-hatchling python-installer)

source=(kontrol_src.tar.zst)
sha256sums=(SKIP)

build() {
    python -m build --wheel --no-isolation
}

package() {
    python -m installer --destdir=${pkgdir} dist/${PKG_NAME}-${PKG_VERSION}*.whl

    install -Dm644 systemd/kwinctl.service ${pkgdir}/usr/lib/systemd/user/kwinctl.service

    install -Dm644 src/kontrol/kwinctl/kwinctl.js     ${pkgdir}/usr/share/kwinctl/kwinctl.js
    install -Dm644 src/kontrol/kwinctl/rules.yaml     ${pkgdir}/usr/share/kwinctl/rules.yaml
    install -Dm644 src/kontrol/kwinctl/commands.yaml  ${pkgdir}/usr/share/kwinctl/commands.yaml
    install -Dm644 src/kontrol/kwinctl/overrides.yaml ${pkgdir}/usr/share/kwinctl/overrides.yaml
}
